<IfModule mod_rewrite.c>
    RewriteEngine On

    # Handle CORS preflight (OPTIONS) before anything else — return 200 immediately
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]

    # Canonical: force HTTPS + www
    # Fires when: HTTP (not HTTPS) OR bare domain (no www) — except /.well-known/
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^adalyzeai\.xyz$ [NC]
    RewriteCond %{REQUEST_URI} !^/\.well-known/
    RewriteRule ^(.*)$ https://www.adalyzeai.xyz/$1 [R=301,L]

    # Pass Authorization header to PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteBase /

    # BUG-CORS-001 fix: route /api/* through same-origin PHP proxy.
    # Browser calls dev.adalyzeai.xyz/api/* (same origin → no CORS preflight).
    # api-proxy.php forwards server-side to dev.evraapp.top with a clean response.
    RewriteRule ^api/(.*)$ /api-proxy.php?_proxy_path=$1 [QSA,L]

    # Pass through existing files and directories (assets, _next, App/, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Map clean URL /foo → /foo.html (Next.js static export routing)
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
    RewriteRule ^ %{REQUEST_URI}.html [L]

    # Custom 404 (Next.js generates this file)
    ErrorDocument 404 /404.html
</IfModule>

# Disable directory listing
Options -Indexes

# Allow images to load without Content-Type override
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|avif)$">
    Header unset Content-Type
</FilesMatch>

# CORS headers for PHP API files
# "always" ensures headers fire on ALL responses including OPTIONS (204/200) and errors
<FilesMatch "\.php$">
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, OPTIONS, PATCH, DELETE"
    Header always set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, Token"
    Header always set Access-Control-Expose-Headers "Token"
    Header always set Access-Control-Max-Age "3600"
</FilesMatch>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php81" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

<IfModule php8_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 128M
   php_value post_max_size 120M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php81"
   php_value upload_max_filesize 100M
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 128M
   php_value post_max_size 120M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php81"
   php_value upload_max_filesize 100M
   php_flag zlib.output_compression Off
</IfModule>
