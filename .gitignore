# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Nexus SDLC framework (agent-generated, not source)
.nexus/results/
.nexus/*.backup
.nexus/*.pre-upgrade-backup
.backups/

# Claude Code agent memory & settings (framework-generated)
.claude/

# Playwright / test artifacts
playwright-report/
test-results/
e2e/debug-*.spec.ts
e2e/real-login-test.spec.ts
