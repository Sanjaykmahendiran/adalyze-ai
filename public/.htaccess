<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Pass through existing files and directories (assets, _next, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Map clean URL /foo → /foo.html (works for nested paths too)
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
    RewriteRule ^ %{REQUEST_URI}.html [L]

    # Custom 404 (Next.js generates this file)
    ErrorDocument 404 /404.html
</IfModule>
